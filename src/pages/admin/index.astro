---
// Admin login page - standalone, no Base layout
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AVORIX LAB — Admin Panel</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-[380px]">
    <div class="text-center mb-8">
      <h1 class="font-display text-[1.3rem] font-extrabold tracking-[.06em] text-white mb-2">AVORIX LAB</h1>
      <p class="font-mono text-[.74rem] text-muted2 tracking-[.04em]">Admin Panel</p>
    </div>

    <form id="loginForm" class="bg-card border border-line rounded-2xl p-8">
      <div class="mb-5">
        <label class="block font-mono text-[.72rem] text-muted2 tracking-[.06em] mb-2 uppercase" for="username">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          required
          class="w-full bg-[var(--color-bg)] border border-line2 rounded-xl px-4 py-3 text-white text-[.88rem] font-mono focus:outline-none focus:border-accent transition-colors"
          placeholder="admin"
        />
      </div>
      <div class="mb-6">
        <label class="block font-mono text-[.72rem] text-muted2 tracking-[.06em] mb-2 uppercase" for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          required
          class="w-full bg-[var(--color-bg)] border border-line2 rounded-xl px-4 py-3 text-white text-[.88rem] font-mono focus:outline-none focus:border-accent transition-colors"
          placeholder="••••••••"
        />
      </div>

      <div id="errorMsg" class="hidden text-red-400 text-[.78rem] font-mono mb-4 text-center"></div>

      <button
        type="submit"
        class="w-full bg-white text-[var(--color-bg)] font-bold text-[.88rem] py-3.5 rounded-xl hover:bg-accent transition-colors cursor-pointer border-none"
      >
        Login
      </button>
    </form>

    <p class="text-center mt-6 font-mono text-[.7rem] text-muted">
      <a href="/" class="text-muted2 hover:text-accent transition-colors no-underline">← Kembali ke website</a>
    </p>
  </div>

  <script>
    const form = document.getElementById('loginForm') as HTMLFormElement;
    const errorMsg = document.getElementById('errorMsg') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');

      const username = (document.getElementById('username') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });

        const data = await res.json();

        if (data.success) {
          window.location.href = '/admin/dashboard';
        } else {
          errorMsg.textContent = data.message || 'Login gagal. Cek username dan password.';
          errorMsg.classList.remove('hidden');
        }
      } catch (err) {
        errorMsg.textContent = 'Terjadi error. Coba lagi.';
        errorMsg.classList.remove('hidden');
      }
    });
  </script>
</body>
</html>

<style is:global>
  @import '../../styles/global.css';
</style>
