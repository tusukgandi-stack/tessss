---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const tags = ['Semua', 'AI Update', 'Bansos AI', 'Tutorial', 'Tools'];
---

<Base title="Blog — AVORIX LAB" description="Artikel terbaru seputar AI, automation, dan teknologi digital.">

  <section class="pt-36 pb-20 px-8 max-w-[1180px] mx-auto">
    <div class="r text-center mb-12">
      <p class="font-mono text-[.72rem] tracking-[.12em] text-accent mb-3 uppercase">Insights & Articles</p>
      <h1 class="font-display text-[2.2rem] md:text-[3rem] font-extrabold tracking-[-0.02em]">Blog</h1>
      <p class="text-muted2 text-[1rem] mt-4 max-w-[480px] mx-auto">Berita AI terbaru, tutorial automation, dan info tools gratis untuk kamu.</p>
    </div>

    <!-- Filter Buttons -->
    <div class="flex items-center justify-center gap-2 flex-wrap mb-10">
      {tags.map((tag, i) => (
        <button
          class={`filter-btn font-mono text-[.76rem] tracking-[.05em] px-4 py-2 rounded-full border transition-all cursor-pointer ${i === 0 ? 'bg-accent text-[var(--color-bg)] border-accent' : 'bg-transparent text-muted2 border-line2 hover:border-accent hover:text-accent'}`}
          data-tag={tag}
        >
          {tag}
        </button>
      ))}
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="articlesGrid">
      {posts.map(post => (
        <article class="r bg-card border border-line rounded-2xl p-6 hover:border-accent transition-colors group article-card" data-tag={post.data.tag}>
          <div class="text-3xl mb-3">{post.data.emoji || '📝'}</div>
          <span class="font-mono text-[.68rem] text-accent tracking-[.08em] uppercase">{post.data.tag}</span>
          <h2 class="font-display font-bold text-[1.05rem] mt-2 mb-2 text-white group-hover:text-accent transition-colors">{post.data.title}</h2>
          <p class="text-muted2 text-[.84rem] leading-relaxed line-clamp-2 mb-4">{post.data.description}</p>
          <div class="flex items-center justify-between">
            <span class="font-mono text-[.7rem] text-muted">{post.data.date}</span>
            <a href={`/blog/${post.id}`} class="font-mono text-[.74rem] text-accent hover:text-accent2 transition-colors no-underline">
              Baca →
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

</Base>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      // Update active state
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-accent', 'text-[var(--color-bg)]', 'border-accent');
        b.classList.add('bg-transparent', 'text-muted2', 'border-line2');
      });
      btn.classList.remove('bg-transparent', 'text-muted2', 'border-line2');
      btn.classList.add('bg-accent', 'text-[var(--color-bg)]', 'border-accent');

      // Filter articles
      document.querySelectorAll('.article-card').forEach(card => {
        const cardTag = card.getAttribute('data-tag');
        if (tag === 'Semua' || cardTag === tag) {
          (card as HTMLElement).style.display = 'block';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
